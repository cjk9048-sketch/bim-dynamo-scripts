<?xml version="1.0" encoding="utf-8"?>
<!--
  Civil3D 자동 로드 매니페스트.
  이 .bundle 폴더 전체를 아래 위치에 복사하면 Civil3D 시작 시 자동 로드된다:
    %APPDATA%\Autodesk\ApplicationPlugins\DH.Grading.bundle
  Contents 폴더에 빌드 산출물(DH.Grading.Civil.dll, DH.Grading.Core.dll)을 넣을 것.
-->
<ApplicationPackage SchemaVersion="1.0"
                    AppVersion="1.0.0"
                    ProductType="Application"
                    Name="DH 정지(절성토)"
                    Description="계단식 정지 비탈면 자동 생성 (distance-field)">
  <CompanyDetails Name="도화엔지니어링 상하수도부" />
  <Components Description="DH Grading">
    <RuntimeRequirements OS="Win64" Platform="AutoCAD*" SeriesMin="R25.0" SeriesMax="R25.1" />
    <ComponentEntry AppName="DH.Grading"
                    ModuleName="./Contents/DH.Grading.Civil.dll"
                    LoadOnAutoCADStartup="True"
                    PerDocument="False">
      <Commands GroupName="DH_GRADING">
        <Command Global="DHGRADE" Local="DHGRADE" />
        <Command Global="DHGRADESET" Local="DHGRADESET" />
      </Commands>
    </ComponentEntry>
  </Components>
</ApplicationPackage>
